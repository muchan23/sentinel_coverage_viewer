# Copernicus Data Space Ecosystem (CDSE)
# 既存 port_monitoring_system の .env から同じ値をコピーすればOK

CDSE_SEARCH_URL=https://stac.dataspace.copernicus.eu/v1/search
CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
CDSE_CLIENT_ID=cdse-public
CDSE_USERNAME=your-email@example.com
CDSE_PASSWORD=your-password

# CORS (frontend dev server)
ALLOWED_ORIGINS=http://localhost:13100,http://127.0.0.1:13100
